# ═══════════════════════════════════════════════════════════════════════════
# LiveSports — Local Development Environment
# ═══════════════════════════════════════════════════════════════════════════

# ==================== FRONTEND ====================
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_FOOTBALL_KEY=your-api-football-key

# ==================== BACKEND ====================
NODE_ENV=development
PORT=3001
ALLOW_DEMO_DATA=true

# Database
DATABASE_URL=postgresql://livesports:livesports123@localhost:5432/livesports_db

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=livesports-redis-pass

# ==================== JWT ====================
JWT_SECRET=livesports-super-secret-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=livesports-refresh-secret-key-change-in-production-min-32-chars

# ==================== CORS ====================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002
FRONTEND_URL=http://localhost:3000

# ==================== EMAIL (SMTP) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@livesports.com
FROM_NAME=LiveSports

# ==================== AWS S3 / R2 ====================
AWS_ACCESS_KEY=your-access-key
AWS_SECRET_KEY=your-secret-key
AWS_BUCKET=livesports-bucket
AWS_REGION=us-east-1
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=livesports-bucket

# ==================== SOCIAL LOGIN ====================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ==================== STRIPE ====================
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ==================== STREAMING ====================
RTMP_URL=rtmp://your-rtmp-server/live
HLS_URL=https://your-hls-server/hls

# ==================== SPORTS APIs ====================
API_FOOTBALL_KEY=your-api-football-key
RAPIDAPI_KEY=your-rapidapi-key
FOOTBALL_DATA_API_TOKEN=your-football-data-token
# TheSportsDB free public API key — replace with paid key for higher rate limits
THESPORTSDB_API_KEY=123
