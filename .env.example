# ==================== FRONTEND ====================
# In development, leave this as localhost:3001 (the backend port).
# The Next.js proxy in next.config.ts will forward /api/* to this URL,
# eliminating CORS issues when the frontend runs on a different port.
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public API key for sports data (used on client-side for logos/flags)
NEXT_PUBLIC_API_FOOTBALL_KEY=your-api-football-key

# ==================== BACKEND ====================
NODE_ENV=development
PORT=3001
ALLOW_DEMO_DATA=false

# Database
DATABASE_URL=postgresql://livesports:livesports123@localhost:5432/livesports_db

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=livesports-redis-pass

# ─── JWT (REQUIRED in production — must be strong random strings) ─────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production-minimum-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-jwt-key-change-in-production-minimum-32-chars

# Frontend URLs for CORS (comma-separated list for multiple origins)
# Example production: ALLOWED_ORIGINS=https://livesports.com,https://www.livesports.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
FRONTEND_URL=http://localhost:3000

# ─── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@livesports.com
FROM_NAME=LiveSports

# ─── File Uploads (AWS S3 / Cloudflare R2) ────────────────────────────────────
# Recommended image upload sizes:
#   Avatar / Shield / League Logo: 512x512 px, WebP, max 200 KB
#   Flag: 320x240 px, WebP, max 50 KB
#   Banner: 1920x600 px, WebP, max 400 KB
#   News / Thumbnail: 1280x720 px, WebP, max 300 KB
AWS_ACCESS_KEY=your-access-key
AWS_SECRET_KEY=your-secret-key
AWS_BUCKET=livesports-bucket
AWS_REGION=us-east-1

# Cloudflare R2 (alternative to AWS S3)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=livesports-bucket

# ─── Social Login ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# ─── Payment (Stripe) ─────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ─── Streaming ────────────────────────────────────────────────────────────────
RTMP_URL=rtmp://your-rtmp-server/live
HLS_URL=https://your-hls-server/hls

# ─── Sports Data APIs ─────────────────────────────────────────────────────────
# API-Football (api-sports.io) — used for club shields, league logos, live scores
API_FOOTBALL_KEY=your-api-football-key
# RapidAPI — all-sport-live-stream (live HLS streams)
RAPIDAPI_KEY=your-rapidapi-key
# Football-data.org (alternative)
FOOTBALL_DATA_API_TOKEN=your-football-data-token
# TheSportsDB — calendario de ligas e competicoes (chave gratuita: 123)
THESPORTSDB_API_KEY=123
# NewsData.io — noticias de desporto em tempo real (PT + EN) para o blog
# Cria uma chave gratis em https://newsdata.io/register
NEWSDATA_API_KEY=your-newsdata-api-key

# ─── Image Size Guide ─────────────────────────────────────────────────────────
# Type            | Dimensions   | Format     | Max Size
# Avatar          | 512x512 px   | WebP/JPEG  | 200 KB
# Shield/Escudo   | 512x512 px   | SVG/WebP   | 200 KB
# League Logo     | 512x512 px   | SVG/WebP   | 200 KB
# Country Flag    | 320x240 px   | SVG/WebP   | 50 KB
# Main Banner     | 1920x600 px  | WebP/JPEG  | 400 KB
# News Image      | 1280x720 px  | WebP/JPEG  | 300 KB
# Live Thumbnail  | 1280x720 px  | WebP/JPEG  | 300 KB
# Sponsor Logo    | 400x200 px   | SVG/WebP   | 100 KB
