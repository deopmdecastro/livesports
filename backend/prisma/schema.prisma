// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USERS & AUTH ====================
model User {
  id               String    @id @default(cuid())
  name             String
  email            String    @unique
  emailVerified    Boolean   @default(false) @map("email_verified")
  emailVerifiedAt  DateTime? @map("email_verified_at")
  password         String
  avatar           String?
  country          String?
  phone            String?
  role             UserRole  @default(user)
  status           UserStatus @default(active)
  twoFactorEnabled Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?   @map("two_factor_secret")
  lastLoginAt      DateTime? @map("last_login_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  refreshTokens    RefreshToken[]
  subscriptions    Subscription[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  newsArticles     NewsArticle[]
  systemLogs       SystemLog[]
  ticketsCreated   SupportTicket[]  @relation("TicketUser")
  ticketsAssigned  SupportTicket[]  @relation("TicketAssigned")
  supportMessages  SupportMessage[] @relation("MessageUser")

  @@map("users")
}

enum UserRole {
  super_admin
  admin
  moderator
  editor
  creator
  user
  @@map("user_role")
}

enum UserStatus {
  active
  suspended
  banned
  pending
  @@map("user_status")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

// ==================== LIVE STREAMS ====================
model Live {
  id          String     @id @default(cuid())
  title       String
  description String?    @db.Text
  thumbnail   String?
  banner      String?
  sport       SportCategory
  league      String?
  leagueLogo  String?    @map("league_logo")
  teamA       String?
  teamALogo   String?
  teamB       String?
  teamBLogo   String?
  scoreA      Int?
  scoreB      Int?
  streamUrl   String?
  hlsUrl      String?
  m3u8Url     String?
  youtubeUrl  String?    @map("youtube_url")
  youtubeEmbed String?   @map("youtube_embed")
  status      LiveStatus @default(scheduled)
  featured    Boolean    @default(false)
  viewerCount Int        @default(0)
  totalViews  Int        @default(0)
  matchTime   String?
  tags        String[]
  scheduledAt DateTime
  startedAt   DateTime?
  endedAt     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("lives")
}

enum LiveStatus {
  scheduled
  live
  ended
  cancelled
  @@map("live_status")
}

// ==================== EVENTS ====================
model Competition {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  season      String?
  sport       SportCategory?

  description String?
  thumbnail   String?
  banner      String?

  startDate   DateTime?
  endDate     DateTime?

  status      CompetitionStatus @default(active)
  format      CompetitionFormat @default(groups)
  themeColor  String?  @map("theme_color")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  events      Event[]

  @@map("competitions")
}

enum CompetitionStatus {
  active
  draft
  completed
  @@map("competition_status")
}

enum CompetitionFormat {
  groups
  league
  knockout
  @@map("competition_format")
}

model Event {
  id            String        @id @default(cuid())
  title         String
  description   String?
  thumbnail     String?

  sport         SportCategory
  competitionId String?

  stage         String?
  roundNumber   Int?
  groupName     String?
  matchNumber   Int?

  league        String?
  teamA         String?
  teamALogo     String?
  teamB         String?
  teamBLogo     String?
  scoreA        Int?
  scoreB        Int?

  matchTime     String?

  scheduledAt   DateTime
  status        EventStatus   @default(upcoming)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("events")

  competition   Competition?  @relation(fields: [competitionId], references: [id], onDelete: SetNull)
}

enum EventStatus {
  upcoming
  live
  finished
  cancelled
  @@map("event_status")
}


// ==================== SPORT CATEGORIES ====================
enum SportCategory {
  football
  basketball
  tennis
  ufc
  f1
  volleyball
  baseball
  other
  @@map("sport_category")
}

model Category {
  id          String        @id @default(cuid())
  name        String        @unique
  slug        String        @unique
  description String?
  icon        String?
  sport       SportCategory
  color       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("categories")
}

// ==================== ADS ====================
model Ad {
  id         String    @id @default(cuid())
  title      String
  campaign   String?
  position   AdPosition
  format     AdFormat
  content    String    @db.Text
  imageUrl   String?
  videoUrl   String?
  clickUrl   String?
  width      Int?
  height     Int?
  impressions Int     @default(0)
  clicks     Int      @default(0)
  ctr        Float    @default(0)
  revenue    Float    @default(0)
  status     AdStatus @default(active)
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("ads")
}

enum AdPosition {
  header
  sidebar
  footer
  in_content
  player
  popup
  live_preroll
  @@map("ad_position")
}

enum AdFormat {
  banner
  video
  html
  script
  @@map("ad_format")
}

enum AdStatus {
  active
  paused
  expired
  draft
  @@map("ad_status")
}

// ==================== NEWS ====================
model NewsArticle {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   @db.Text
  thumbnail   String?
  sport       SportCategory?
  tags        String[]
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  published   Boolean  @default(false)
  featured    Boolean  @default(false)
  views       Int      @default(0)
  publishedAt DateTime?
  metaTitle   String?
  metaDesc    String?
  ogImage     String?
  language        String?        // 'pt' | 'en' | null (unknown / pre-dates this field)
  translationOfId String?        @map("translation_of_id")
  translationOf   NewsArticle?   @relation("NewsArticleTranslation", fields: [translationOfId], references: [id], onDelete: SetNull)
  translations    NewsArticle[]  @relation("NewsArticleTranslation")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("news_articles")
}

// ==================== SUBSCRIPTIONS ====================
model Plan {
  id           String         @id @default(cuid())
  name         String
  type         PlanType
  price        Float
  currency     String         @default("BRL")
  interval     BillingInterval
  features     String[]
  maxDevices   Int            @default(1)
  hdQuality    Boolean        @default(false)
  adsRemoved   Boolean        @default(false)
  active       Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  subscriptions Subscription[]

  @@map("plans")
}

enum PlanType {
  free
  basic
  premium
  enterprise
  @@map("plan_type")
}

enum BillingInterval {
  monthly
  yearly
  @@map("billing_interval")
}

model Subscription {
  id         String             @id @default(cuid())
  userId     String
  user       User               @relation(fields: [userId], references: [id])
  planId     String
  plan       Plan               @relation(fields: [planId], references: [id])
  status     SubscriptionStatus @default(active)
  startDate  DateTime
  endDate    DateTime
  autoRenew  Boolean            @default(true)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@map("subscriptions")
}

enum SubscriptionStatus {
  active
  cancelled
  expired
  trial
  @@map("subscription_status")
}

// ==================== NOTIFICATIONS ====================
model Notification {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String?
  type      NotificationType @default(system)
  link      String?
  meta      Json?
  read      Boolean          @default(false)
  readAt    DateTime?        @map("read_at")
  createdAt DateTime         @default(now()) @map("created_at")

  @@map("notifications")
}

enum NotificationType {
  info
  success
  warning
  error
  live
  new_ticket
  ticket_reply
  ticket_status_change
  poll_milestone
  creator_application
  channel_status_change
  system
  @@map("notification_type")
}

// ==================== BANNERS ====================
model Banner {
  id        String        @id @default(cuid())
  title     String
  imageUrl  String
  linkUrl   String?
  position  BannerPosition
  active    Boolean       @default(true)
  startDate DateTime?
  endDate   DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@map("banners")
}

enum BannerPosition {
  hero
  sidebar
  in_content
  @@map("banner_position")
}

// ==================== AUDIT LOGS ====================
model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  resource   String
  resourceId String?
  details    Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}

// ==================== API KEYS ====================
enum ApiKeyStatus {
  active
  inactive
  expired
  @@map("api_key_status")
}

enum ApiUsageType {
  live_streams
  game_events
  game_data
  statistics
  competitions
  teams
  players
  shields
  logos
  flags
  standings
  odds
  news
  @@map("api_usage_type")
}

model ApiKey {
  id            String        @id @default(cuid())
  name          String        @db.VarChar(200)
  description   String?       @db.Text
  provider      String        @db.VarChar(200)
  baseUrl       String?       @map("base_url")
  keyValue      String        @map("key_value")
  status        ApiKeyStatus  @default(active)
  priority      Int           @default(1)
  requestLimit  Int?          @map("request_limit")
  requestsUsed  Int           @default(0) @map("requests_used")
  errorCount    Int           @default(0) @map("error_count")
  lastUsedAt    DateTime?     @map("last_used_at")
  lastSyncedAt  DateTime?     @map("last_synced_at")
  expiresAt     DateTime?     @map("expires_at")
  usageTypes    ApiUsageType[] @default([]) @map("usage_types")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  @@map("api_keys")
}

// ==================== SYSTEM LOGS ====================
enum LogLevel {
  debug
  info
  warn
  error
  fatal
  @@map("log_level")
}

enum LogService {
  api
  player
  sync
  auth
  admin
  database
  stream
  system
  @@map("log_service")
}

model SystemLog {
  id         String     @id @default(cuid())
  level      LogLevel   @default(info)
  service    LogService @default(system)
  message    String     @db.Text
  details    Json?
  userId     String?    @map("user_id")
  user       User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  requestId  String?    @map("request_id")
  ip         String?
  userAgent  String?    @map("user_agent")
  createdAt  DateTime   @default(now()) @map("created_at")

  @@map("system_logs")
}

// ==================== SUPPORT ====================
enum TicketStatus {
  open
  pending
  resolved
  closed
  @@map("ticket_status")
}

enum TicketPriority {
  low
  medium
  high
  critical
  @@map("ticket_priority")
}

enum TicketCategory {
  player
  account
  billing
  stream
  content
  technical
  other
  @@map("ticket_category")
}

model SupportTicket {
  id           String          @id @default(cuid())
  subject      String          @db.VarChar(500)
  description  String          @db.Text
  status       TicketStatus    @default(open)
  priority     TicketPriority  @default(medium)
  category     TicketCategory  @default(other)
  userId       String?         @map("user_id")
  user         User?           @relation("TicketUser", fields: [userId], references: [id], onDelete: SetNull)
  assignedTo   String?         @map("assigned_to")
  assignedUser User?           @relation("TicketAssigned", fields: [assignedTo], references: [id], onDelete: SetNull)
  resolvedAt   DateTime?       @map("resolved_at")
  closedAt     DateTime?       @map("closed_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  messages     SupportMessage[]

  @@map("support_tickets")
}

model SupportMessage {
  id         String        @id @default(cuid())
  ticketId   String        @map("ticket_id")
  ticket     SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId     String?       @map("user_id")
  user       User?         @relation("MessageUser", fields: [userId], references: [id], onDelete: SetNull)
  message    String        @db.Text
  isAdmin    Boolean       @default(false) @map("is_admin")
  createdAt  DateTime      @default(now()) @map("created_at")

  @@map("support_messages")
}

